{
  "project": "blackdorvelus-star/lyss",
  "workflows": [
    {
      "name": "docs-generation",
      "description": "Generate documentation on push",
      "trigger": "push",
      "agent": "lyss-docs-agent",
      "actions": [
        "generate_docs",
        "update_readme"
      ],
      "active": true
    },
    {
      "name": "test-automation",
      "description": "Run tests on pull request",
      "trigger": "pull_request",
      "agent": "lyss-tests-agent",
      "actions": [
        "run_tests",
        "report_coverage"
      ],
      "active": true
    }
  ],
  "secrets": {
    "api_key": "",
    "project_id": "",
    "region": ""
  }
}
